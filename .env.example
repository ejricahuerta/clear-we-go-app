# Supabase (same for admin and crew apps)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Google OAuth (admin app only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Twilio (Phase 5)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Resend (invites + email). Required for invite emails.
RESEND_API_KEY=
# Optional: from address (e.g. Clear We Go <noreply@clearwego.ca>). Defaults to Resend onboarding.
# RESEND_FROM=
# Admin app: crew app URL for invite links (default https://crew.clearwego.ca). Use http://localhost:3001 in dev if crew runs there.
# CREW_APP_URL=

# Stripe (Phase 2, disabled by default)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
