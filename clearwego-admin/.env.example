# Canonical app URL (required in production so redirects don't go to localhost)
# e.g. https://admin.clearwego.ca
NEXT_PUBLIC_APP_URL=

# Supabase (same project as crew app)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Invite emails (Resend)
RESEND_API_KEY=
# Optional
# RESEND_FROM=Clear We Go <noreply@clearwego.ca>
# CREW_APP_URL=https://crew.clearwego.ca

# Google OAuth (admin only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Quo / OpenPhone API (call summary webhook: POST /api/webhooks/quo/call-summary)
# Create webhook via https://www.quo.com/docs/mdx/api-reference/webhooks/create-a-new-webhook-for-call-summaries
# Use the webhook "key" as QUO_WEBHOOK_SECRET; send the same value in the Authorization header (or "Bearer <key>").
QUO_API_KEY=
QUO_WEBHOOK_SECRET=
